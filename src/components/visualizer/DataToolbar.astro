---
import ColumnFilterInput from "./ColumnFilterInput.astro";
import FilterButton from "./FilterButton.astro";
import ExportButton from "./ExportButton.astro";

interface Props {
  showingRows?: number;
  totalRecords?: number;
}

const { showingRows = 0, totalRecords = 0 } = Astro.props as Props;
---

<div
  class="shrink-0 px-8 py-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-border-dark"
>
  <!-- Left side: Title and subtitle -->
  <div>
    <h2 class="text-xl font-bold tracking-tight text-text-off-white">
      Data Preview
    </h2>
    <p class="text-xs text-text-light-gray mt-1">
      Showing <span data-showing-rows>{showingRows}</span> rows from <span
        data-total-records>{totalRecords}</span
      > total records
    </p>
  </div>

  <!-- Right side: Controls -->
  <div
    data-toolbar-counters
    class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 shrink-0"
  >
    <!-- Delimiter Badge -->
    <div
      class="px-3 py-2 rounded-md bg-surface-card border border-border-dark text-xs font-medium text-text-light-gray text-center sm:text-left whitespace-nowrap"
      title="Detected delimiter"
    >
      <span class="sr-only">Delimiter:</span>
      <span data-delimiter-badge>Comma (,)</span>
    </div>

    <ColumnFilterInput />
    <FilterButton />
    <ExportButton />
  </div>
</div>
